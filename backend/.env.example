# Supabase project credentials (Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# JWT Secret (long random string, e.g. `openssl rand -hex 32`)
JWT_SECRET=your_super_secret_jwt_key_here

# Admin (Super Admin) credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password_here

# Comma-separated list of origins allowed to call the API. Only needed for
# local dev / extra domains — same-origin requests in production don't need it.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# Port (optional, defaults to 5000)
PORT=5000

# Gmail account used to send password-reset emails via Nodemailer.
# EMAIL_USER is the Gmail address itself. EMAIL_APP_PASSWORD is a 16-character
# App Password (NOT your regular Gmail password) — generate one at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification
# to be enabled on the Google account first).
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password

# Public URL of the deployed app, used to build the link inside reset emails.
# Defaults to the request's own host if not set.
FRONTEND_URL=https://stone-tracker-six.vercel.app
