{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite",
      "routes": [
        { "src": "/((?!.*\\.).*)", "transforms": [ { "type": "request.path", "op": "set", "args": "/index.html" } ] }
      ]
    },
    "backend": {
      "root": "backend",
      "entrypoint": "server.js"
    }
  },
  "rewrites": [
    { "source": "/api(/.*)?", "destination": { "type": "service", "service": "backend" } },
    { "source": "/(.*)", "destination": { "type": "service", "service": "frontend" } }
  ]
}
